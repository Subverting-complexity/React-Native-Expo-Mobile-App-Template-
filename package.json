{
  "name": "expo-template",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "quality": "npm run lint && npm run typecheck && npm run test -- --coverage --passWithNoTests",
    "build:dev": "npx eas-cli build --profile development",
    "build:preview": "npx eas-cli build --profile preview",
    "build:prod": "npx eas-cli build --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production",
    "submit:android": "npx eas-cli submit --platform android --profile production",
    "verify:expo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/VerifyExpoAccount.ps1",
    "deploy:ios": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/DeployiOSTestFlight.ps1",
    "deploy:android": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/DeployAndroidPlayStore.ps1",
    "bump": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/BumpBuildNumber.ps1",
    "check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/QualityGate.ps1 -Mode ci"
  },
  "dependencies": {
    "@expo-google-fonts/atkinson-hyperlegible": "^0.4.1",
    "@expo/metro-runtime": "~56.0.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.13",
    "expo-modules-core": "^56.0.15",
    "expo-router": "~56.2.9",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^13.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.17",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "roots": [
      "<rootDir>/app",
      "<rootDir>/src"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "app/**/*.{ts,tsx}",
      "!**/__tests__/**",
      "!**/*.test.{ts,tsx}",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  }
}
