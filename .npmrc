# Expo SDK 56 ships react-native-reanimated 4, whose react-native-worklets
# peer range is stricter than some transitive deps declare. npm 7+ treats
# that as an ERESOLVE error on a fresh install. legacy-peer-deps restores
# npm 6 behaviour (warn, don't fail) so `npm install` works out of the box.
legacy-peer-deps=true
